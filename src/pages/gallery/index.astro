  "img-006": { prompt: "Cozy home office in a converted attic, exposed wooden beams, large dormer window with afternoon light, built-in bookshelves filled with books and plants, a vintage wooden desk with a modern monitor, warm reading lamp, plaid blanket on chair, hygge aesthetic", params: "Content Credentials: on · Aspect ratio: 4:3 · Style: Photo", note: "The 'hygge aesthetic' reference is surprisingly precise — it communicates warmth, texture, soft lighting, and comfort as a single concept. Firefly's commercially-safe training makes it a solid choice for interior design mockups." },
  "img-007": { prompt: "Abstract art inspired by data flow, flowing streams of light particles in deep navy and amber, connections branching like neural networks, glowing nodes, dark background, generative art aesthetic, painterly, digital fine art", params: "Style: None (let the model interpret freely) · Aspect ratio: 16:9", note: "Canva's free plan includes AI image generation. For abstract work, leaving the Style selector on 'None' and letting the prompt drive the visual gives more interesting results than using a preset." },
  "img-008": { prompt: "Rustic mountain lodge exterior at twilight, warm amber light glowing through windows, snow on the pine trees, clear sky beginning to show stars, smoke from chimney, wide establishing shot, cinematic, national geographic style photography, no people, no text signs, no cars, no power lines", params: "Style: Realistic · Aspect ratio: 16:9", note: "Ideogram v2 handles architectural exteriors very well. The 'twilight' time specification reliably produces the blue-hour color palette with interior warm light." },
};

let activeId: string | null = null;

// Tab filtering — by tag (not just type)
document.querySelectorAll<HTMLButtonElement>('.gallery-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.gallery-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const filter = tab.dataset.filter ?? 'all';
    document.querySelectorAll<HTMLElement>('.gallery-card').forEach(card => {
      const tags = (card.dataset.tags ?? '').split(',');
      card.hidden = filter !== 'all' && !tags.includes(filter);
    });
    if (activeId) {
      const active = document.querySelector<HTMLElement>(`[data-id="${activeId}"]`);
      if (active?.hidden) closeDetail();
    }
  });
});

// Card click → detail panel
document.querySelectorAll<HTMLButtonElement>('.gallery-card').forEach(card => {
  card.addEventListener('click', () => {
    const id = card.dataset.id!;
    if (activeId === id) { closeDetail(); return; }
    activeId = id;
    document.querySelectorAll('.gallery-card').forEach(c => c.classList.remove('active'));
    card.classList.add('active');
    renderDetail(card);
    setTimeout(() => document.getElementById('gallery-detail')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 80);
  });
});

function closeDetail() {
  activeId = null;
  const el = document.getElementById('gallery-detail')!;
  el.classList.remove('open');
  el.innerHTML = '';
  document.querySelectorAll('.gallery-card').forEach(c => c.classList.remove('active'));
}

function renderDetail(card: HTMLElement) {
  const id = card.dataset.id!;
  const img = card.querySelector('img')!;
  const title = card.querySelector('.gc-title')!.textContent ?? '';
  const model = card.querySelector('.model-badge')!.textContent ?? '';
  const data = ITEMS[id] ?? { prompt: '', params: '', note: '' };

  const el = document.getElementById('gallery-detail')!;
  el.innerHTML = `
    <div class="gd-header">
      <div class="gd-image">
        <img src="${escapeHTML(img.src)}" alt="${escapeHTML(title)}" />
      </div>
      <div class="gd-info">
        <div>
          <div class="gd-model">${escapeHTML(model)}</div>
          <h2 class="gd-title">${escapeHTML(title)}</h2>
        </div>
        <div>
          <div class="gd-section-label">Prompt used</div>
          <div class="gd-prompt-box">${escapeHTML(data.prompt)}</div>
        </div>
        <div>
          <div class="gd-section-label">Parameters</div>
          <div class="gd-params">${escapeHTML(data.params)}</div>
        </div>
        <div>
          <div class="gd-section-label">What made it work</div>
          <p class="gd-note">${escapeHTML(data.note)}</p>
        </div>
        <div class="gd-actions">
          <button class="btn btn-primary btn-sm" id="copy-prompt-btn">📋 Copy prompt</button>
          <button class="btn btn-secondary btn-sm gd-close" id="close-detail-btn">✕ Close</button>
          <span class="copy-confirm" id="copy-confirm">Copied!</span>
        </div>
      </div>
    </div>`;
  el.classList.add('open');

  document.getElementById('copy-prompt-btn')!.addEventListener('click', async () => {
    await navigator.clipboard.writeText(data.prompt).catch(() => {});
    const c = document.getElementById('copy-confirm')!;
    c.style.display = 'inline';
    setTimeout(() => { c.style.display = 'none'; }, 2200);
  });
  document.getElementById('close-detail-btn')!.addEventListener('click', closeDetail);
}
</script>
