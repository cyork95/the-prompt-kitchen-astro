---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const guardrails = await getCollection('guardrails');
const sorted = guardrails.sort((a, b) => a.data.order - b.data.order);

const categoryColors: Record<string, string> = {
  accuracy: '#B45309',
  trust: '#D97706',
  privacy: '#2563EB',
  bias: '#7C3AED',
  safety: '#059669',
};

const categoryLabels: Record<string, string> = {
  accuracy: '🎯 Accuracy',
  trust: '🤝 Trust',
  privacy: '🔒 Privacy',
  bias: '⚖️ Bias',
  safety: '🛡️ Safety',
};

const categories = ['All', ...new Set(sorted.map(g => g.data.category))];
---
<Page
  title="Kitchen Guardrails"
  description="Practical, non-corporate guide to AI safety — avoiding hallucinations, verifying output, spotting bias, and knowing when to trust AI."
>
  <section class="page-hero container">
    <h1><span class="h1-emoji">🛡️</span> Kitchen Guardrails</h1>
    <p>Practical AI safety — not corporate policy. How to use AI responsibly without overthinking it.</p>
  </section>

  <div class="container gr-layout">

    <!-- Search bar -->
    <div class="search-bar" role="search">
      <span aria-hidden="true">🔍</span>
      <input
        type="text"
        id="gr-search"
        placeholder="Search guardrails…"
        aria-label="Search guardrails"
        autocomplete="off"
      />
    </div>

    <!-- Category filter -->
    {categories.length > 1 && (
      <div class="filter-pills" role="group" aria-label="Filter by category">
        {categories.map(cat => (
          <button
            class={`filter-pill ${cat === 'All' ? 'active' : ''}`}
            data-category={cat}
          >
            {cat === 'All' ? 'All' : (categoryLabels[cat] ?? cat)}
          </button>
        ))}
      </div>
    )}

    <!-- Results count -->
    <p class="results-count" id="gr-count" aria-live="polite">
      {sorted.length} guardrail{sorted.length !== 1 ? 's' : ''}
    </p>

    {sorted.length > 0 ? (
      <div class="gr-grid" id="gr-grid">
        {sorted.map(async gr => {
          const { Content } = await gr.render();
          const color = categoryColors[gr.data.category] ?? '#B85C20';
          return (
            <div
              class="gr-card"
              style={`--gr-color: ${color}`}
              data-category={gr.data.category}
              data-title={gr.data.title.toLowerCase()}
              data-analogy={(gr.data.analogy ?? '').toLowerCase()}
            >
              <div class="gr-card-header">
                <span class="gr-tag" style={`color: ${color}`}>{categoryLabels[gr.data.category] ?? gr.data.category}</span>
                <h3 class="gr-title">{gr.data.title}</h3>
                <p class="gr-analogy">🍳 {gr.data.analogy}</p>
              </div>
              <details class="gr-detail">
                <summary>Read the guardrail</summary>
                <div class="gr-content prose">
                  <Content />
                </div>
              </details>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">🛡️</span>
        <p>Guardrails content coming soon.</p>
        <a href="/prompts/" style="color:var(--accent)">Browse the Recipe Book →</a>
      </div>
    )}

    <!-- No results -->
    <div class="no-results" id="gr-no-results" hidden>
      <p>No guardrails match "<span id="gr-query"></span>".</p>
      <button class="filter-pill active" id="gr-clear">Clear search</button>
    </div>

    <!-- Further Reading -->
    <section class="gr-reading">
      <h2 class="reading-heading">Further Reading</h2>
      <div class="gr-reading-list">
        {[
          {
            title: "Google's AI Overviews Can Scam You. Here's How to Stay Safe",
            source: "Wired",
            tag: "AI Safety",
            desc: "AI-generated search summaries are being exploited to surface scam sites and misinformation at scale. How the attack works and practical steps to protect yourself.",
            url: "https://www.wired.com/story/googles-ai-overviews-can-scam-you-heres-how-to-stay-safe/",
          },
          {
            title: "Make AI Check Its Work",
            source: "The Prompt Kitchen",
            tag: "Recipe",
            desc: "A practical recipe for forcing AI to verify its own output before you trust it — layered fact-checking built into the prompt itself.",
            url: "/prompts/ai-fact-check/",
          },
          {
            title: "OWASP LLM Top 10: Prompt Injection & Agent Safety",
            source: "OWASP",
            tag: "Security",
            desc: "The definitive security reference for LLM applications — prompt injection, insecure output handling, training data poisoning, and the 7 other attack vectors every AI builder needs to understand.",
            url: "https://owasp.org/www-project-top-10-for-large-language-model-applications/",
          },
        ].map(item => (
          <a href={item.url} target={item.url.startsWith('http') ? '_blank' : undefined} rel={item.url.startsWith('http') ? 'noopener' : undefined} class="gr-reading-card">
            <div class="gr-reading-tag">{item.tag}</div>
            <strong class="gr-reading-title">{item.title}</strong>
            <span class="gr-reading-source">{item.source}</span>
            <p class="gr-reading-desc">{item.desc}</p>
          </a>
        ))}
      </div>
    </section>

  </div>
</Page>

<style>
.gr-layout {
  display: flex;
  flex-direction: column;
  gap: var(--s5);
  padding-bottom: var(--s20);
}

.results-count {
  font-size: 0.82rem;
  color: var(--text-3);
  margin: 0;
}

.gr-grid {
  display: flex;
  flex-direction: column;
  gap: var(--s4);
}

.gr-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--gr-color);
  border-radius: var(--r3);
  padding: var(--s5) var(--s6);
}

.gr-card-header {
  margin-bottom: var(--s2);
}

.gr-tag {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  display: block;
  margin-bottom: var(--s2);
}

.gr-title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  margin: 0 0 var(--s2);
}

.gr-analogy {
  font-size: 0.875rem;
  color: var(--text-3);
  font-style: italic;
  margin: 0;
}

.gr-detail {
  margin-top: var(--s4);
}

.gr-detail summary {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--accent);
  cursor: pointer;
  padding: var(--s2) 0;
}

.gr-content {
  padding-top: var(--s4);
  font-size: 0.875rem;
  line-height: 1.7;
}

.no-results {
  text-align: center;
  padding: var(--s12) var(--s8);
  color: var(--text-3);
}

.no-results p {
  margin: 0 0 var(--s4);
  font-size: 0.9rem;
}

.no-results span {
  font-style: italic;
  color: var(--text-2);
}

.gr-reading { margin-top: var(--s6); padding-top: var(--s8); border-top: 1px solid var(--border); }
.reading-heading { font-family: var(--font-display); font-size: 1.25rem; margin: 0 0 var(--s5); }
.gr-reading-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--s4); }
.gr-reading-card { display: flex; flex-direction: column; gap: var(--s2); background: var(--surface); border: 1px solid var(--border); border-radius: var(--r3); padding: var(--s5); text-decoration: none; color: var(--text); transition: background var(--t-fast); }
.gr-reading-card:hover { background: var(--bg-alt); }
.gr-reading-tag { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--accent); }
.gr-reading-title { font-size: 0.9rem; font-weight: 700; color: var(--text); line-height: 1.4; }
.gr-reading-source { font-size: 0.72rem; color: var(--text-3); }
.gr-reading-desc { font-size: 0.82rem; color: var(--text-2); margin: 0; line-height: 1.6; }
</style>

<script>
const searchInput = document.getElementById('gr-search') as HTMLInputElement;
const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
const cards = document.querySelectorAll<HTMLElement>('.gr-card');
const countEl = document.getElementById('gr-count');
const noResults = document.getElementById('gr-no-results');
const querySpan = document.getElementById('gr-query');
const clearBtn = document.getElementById('gr-clear');

let activeCategory = 'All';
let searchQuery = '';

function updateDisplay() {
  let visible = 0;
  cards.forEach(card => {
    const matchCat = activeCategory === 'All' || card.dataset.category === activeCategory;
    const title = card.dataset.title ?? '';
    const analogy = card.dataset.analogy ?? '';
    const matchSearch = !searchQuery ||
      title.includes(searchQuery) ||
      analogy.includes(searchQuery) ||
      (card.dataset.category ?? '').includes(searchQuery);
    const show = matchCat && matchSearch;
    card.hidden = !show;
    if (show) visible++;
  });

  if (countEl) countEl.textContent = `${visible} guardrail${visible !== 1 ? 's' : ''}`;

  if (noResults && querySpan) {
    noResults.hidden = visible > 0 || !searchQuery;
    querySpan.textContent = searchQuery;
  }
}

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    if (pill.id === 'gr-clear') return;
    activeCategory = pill.dataset.category ?? 'All';
    pills.forEach(p => p.classList.toggle('active', p === pill));
    updateDisplay();
  });
});

searchInput?.addEventListener('input', () => {
  searchQuery = searchInput.value.toLowerCase().trim();
  updateDisplay();
});

clearBtn?.addEventListener('click', () => {
  searchQuery = '';
  searchInput.value = '';
  updateDisplay();
});
</script>
