---
import Page from '../../layouts/Page.astro';
---
<Page
  title="My Kitchen"
  description="Your saved AI prompt recipes — your personal collection, stored in your browser."
>
  <section class="page-hero container">
    <h1><span class="h1-emoji">🍽️</span> My Kitchen</h1>
    <p>Your saved recipes — stored right here in your browser. No account needed.</p>
  </section>

  <div class="container my-kitchen-layout">
    <div id="favorites-grid" class="card-grid" hidden>
      <!-- Populated by JS -->
    </div>

    <div id="empty-state" class="empty-state">
      <span class="empty-icon">🤍</span>
      <p>You haven't saved any recipes yet.</p>
      <a href="/prompts/" class="filter-pill active" style="display:inline-block;text-decoration:none;">
        Browse Recipes →
      </a>
    </div>
  </div>
</Page>

<style>
.my-kitchen-layout {
  padding-bottom: var(--s20);
  min-height: 40vh;
}
</style>

<script>
import { getFavorites, saveFavorites, type FavoriteItem } from '../../utils/storage';

function escapeHTML(str: string): string {
  return str.replace(/[&<>'"]/g, (tag) => {
    const chars: Record<string, string> = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;'
    };
    return chars[tag] || tag;
  });
}

function renderFavorites() {
  const favs = getFavorites();
  const keys = Object.keys(favs);
  const grid = document.getElementById('favorites-grid')!;
  const empty = document.getElementById('empty-state')!;

  if (keys.length === 0) {
    grid.hidden = true;
    empty.hidden = false;
    return;
  }

  grid.hidden = false;
  empty.hidden = true;
  grid.innerHTML = '';

  keys.forEach(id => {
    const fav = favs[id];
    const card = document.createElement('div');
    card.className = 'recipe-card';
    card.style.position = 'relative';
    card.innerHTML = `
      <div class="recipe-card-meta">
        <span class="recipe-card-category">${escapeHTML(fav.category || '')}</span>
      </div>
      <h3><a href="${escapeHTML(fav.url || '')}" style="color:inherit;text-decoration:none;">${escapeHTML(fav.title || '')}</a></h3>
      <div class="recipe-card-footer">
        <a href="${escapeHTML(fav.url || '')}" class="recipe-card-read">Read recipe →</a>
        <button class="heart-btn remove-btn" data-id="${id}" aria-label="Remove from saved">❤️</button>
      </div>
    `;

    const removeBtn = card.querySelector<HTMLButtonElement>('.remove-btn')!;
    removeBtn.addEventListener('click', () => {
      const favs = getFavorites();
      delete favs[id];
      saveFavorites(favs);
      card.remove();
      if (Object.keys(getFavorites()).length === 0) {
        grid.hidden = true;
        empty.hidden = false;
      }
    });

    grid.appendChild(card);
  });
}

renderFavorites();
</script>
