---
import Page from '../../layouts/Page.astro';
---
<Page
  title="Spice Rack"
  description="Build your own AI prompt from reusable components — mix and match role frames, context, format and more."
>
  <section class="page-hero container">
    <h1>🌶️ The Spice Rack</h1>
    <p>Build your own prompt by combining reusable components. Mix a role frame with some context, add a format specifier, and you've got a custom recipe.</p>
  </section>

  <div class="container spice-layout">

    <div class="builder-panel" id="builder">
      <h2>Prompt Builder</h2>
      <p class="builder-intro">Select ingredients from each shelf below. Your prompt builds in real time.</p>

      <!-- Output -->
      <div class="builder-output" id="builder-output">
        <div class="output-placeholder" id="output-placeholder">Your prompt will appear here as you add ingredients…</div>
        <pre class="output-text" id="output-text" hidden></pre>
        <div class="output-actions" id="output-actions" hidden>
          <button class="btn btn-primary" id="btn-copy-prompt">Copy Prompt</button>
          <button class="btn btn-secondary" id="btn-clear">Clear all</button>
        </div>
      </div>

      <!-- Shelves -->
      <div class="shelves">

        <div class="shelf">
          <div class="shelf-header">
            <span class="shelf-icon">👤</span>
            <div>
              <h3>Role Frame</h3>
              <p>Who should the AI be?</p>
            </div>
          </div>
          <div class="spice-grid" data-shelf="role">
            {[
              { label: 'Expert', text: 'You are an expert in [field] with 20+ years of experience.' },
              { label: 'Teacher', text: 'You are a patient teacher who explains things simply and checks for understanding.' },
              { label: 'Editor', text: 'You are a professional editor who values clarity, brevity, and precision.' },
              { label: 'Devil\'s Advocate', text: 'You are a rigorous critic. Your job is to find weaknesses in arguments and ideas.' },
              { label: 'Collaborator', text: 'You are a creative collaborator who builds on ideas without taking them over.' },
            ].map(s => (
              <button class="spice-btn" data-shelf="role" data-text={s.text}>{s.label}</button>
            ))}
          </div>
        </div>

        <div class="shelf">
          <div class="shelf-header">
            <span class="shelf-icon">📋</span>
            <div>
              <h3>Context Setter</h3>
              <p>What background does the AI need?</p>
            </div>
          </div>
          <div class="spice-grid" data-shelf="context">
            {[
              { label: 'Audience', text: 'The audience for this is [describe your audience — their background, what they know, what they need].' },
              { label: 'Goal', text: 'My goal is to [describe what you\'re trying to achieve].' },
              { label: 'Constraints', text: 'Constraints: [list any word limits, formats, things to avoid, or requirements].' },
              { label: 'Tone', text: 'Tone: [professional / casual / direct / friendly / academic — choose one].' },
            ].map(s => (
              <button class="spice-btn" data-shelf="context" data-text={s.text}>{s.label}</button>
            ))}
          </div>
        </div>

        <div class="shelf">
          <div class="shelf-header">
            <span class="shelf-icon">📐</span>
            <div>
              <h3>Format Specifier</h3>
              <p>How should the output be structured?</p>
            </div>
          </div>
          <div class="spice-grid" data-shelf="format">
            {[
              { label: 'Bullet list', text: 'Format the output as a bullet list.' },
              { label: 'Numbered steps', text: 'Format as numbered steps in order.' },
              { label: 'Table', text: 'Present the information as a table with clear column headers.' },
              { label: 'Short paragraphs', text: 'Write in short paragraphs of 2–3 sentences each.' },
              { label: 'Under 200 words', text: 'Keep the entire response under 200 words.' },
            ].map(s => (
              <button class="spice-btn" data-shelf="format" data-text={s.text}>{s.label}</button>
            ))}
          </div>
        </div>

        <div class="shelf">
          <div class="shelf-header">
            <span class="shelf-icon">🚧</span>
            <div>
              <h3>Constraints</h3>
              <p>What should the AI avoid?</p>
            </div>
          </div>
          <div class="spice-grid" data-shelf="constraint">
            {[
              { label: 'No jargon', text: 'Avoid jargon and technical terms. If you must use one, define it immediately.' },
              { label: 'No fluff', text: 'Do not pad the response. Cut any sentence that doesn\'t add value.' },
              { label: 'No hedging', text: 'Don\'t hedge excessively. If you\'re uncertain, say so once — then make your best recommendation.' },
              { label: 'Cite uncertainty', text: 'If something is uncertain or contested, flag it explicitly.' },
            ].map(s => (
              <button class="spice-btn" data-shelf="constraint" data-text={s.text}>{s.label}</button>
            ))}
          </div>
        </div>

      </div>
    </div>

    <aside class="spice-sidebar">
      <div class="sidebar-card">
        <h3>💡 How to use</h3>
        <ol>
          <li>Pick a <strong>Role Frame</strong> to set who the AI is</li>
          <li>Add a <strong>Context Setter</strong> to give background</li>
          <li>Choose a <strong>Format</strong> for the output</li>
          <li>Add <strong>Constraints</strong> to sharpen it</li>
          <li>Copy the result and add your actual question at the end</li>
        </ol>
      </div>
      <div class="sidebar-card">
        <h3>🥫 More ingredients</h3>
        <p>The Pantry has more reusable building blocks you can borrow.</p>
        <a href="/pantry/" class="sidebar-link">Visit The Pantry →</a>
      </div>
      <div class="sidebar-card">
        <h3>📖 Ready-made recipes</h3>
        <p>Don't want to build from scratch? Browse the full recipe book.</p>
        <a href="/prompts/" class="sidebar-link">Recipe Book →</a>
      </div>
    </aside>

  </div>
</Page>

<style>
.page-hero {
  padding: var(--s12) 0 var(--s8);
  max-width: var(--container-narrow);
}
.page-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  margin: 0 0 var(--s3);
}
.page-hero p { color: var(--text-2); font-size: 1.05rem; margin: 0; }

.spice-layout {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: var(--s8);
  padding-bottom: var(--s20);
  align-items: start;
}

/* Builder */
.builder-panel h2 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  margin: 0 0 var(--s2);
}
.builder-intro { color: var(--text-3); font-size: 0.9rem; margin: 0 0 var(--s6); }

.builder-output {
  background: var(--surface);
  border: 1.5px solid var(--accent);
  border-radius: var(--r3);
  padding: var(--s5);
  margin-bottom: var(--s8);
  min-height: 80px;
}
.output-placeholder {
  color: var(--text-3);
  font-size: 0.9rem;
  font-style: italic;
}
.output-text {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  line-height: 1.7;
  color: var(--text);
  white-space: pre-wrap;
  word-break: break-word;
  margin: 0 0 var(--s4);
  background: none;
}
.output-actions {
  display: flex;
  gap: var(--s3);
  padding-top: var(--s3);
  border-top: 1px solid var(--border-light);
  flex-wrap: wrap;
}

/* Shelves */
.shelves { display: flex; flex-direction: column; gap: var(--s8); }

.shelf {
  border-top: 2px solid var(--accent);
  padding-top: var(--s5);
}
.shelf-header {
  display: flex;
  align-items: center;
  gap: var(--s3);
  margin-bottom: var(--s4);
}
.shelf-icon { font-size: 1.5rem; line-height: 1; }
.shelf-header h3 { font-family: var(--font-display); font-size: 1.1rem; margin: 0 0 2px; }
.shelf-header p { font-size: 0.78rem; color: var(--text-3); margin: 0; }

.spice-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
}

.spice-btn {
  padding: var(--s2) var(--s4);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  background: var(--surface);
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--text-2);
  cursor: pointer;
  transition: all var(--t-fast);
}
.spice-btn:hover { background: var(--bg-alt); color: var(--text); border-color: var(--text-3); }
.spice-btn.active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 600;
}

/* Sidebar */
.spice-sidebar {
  display: flex;
  flex-direction: column;
  gap: var(--s4);
  position: sticky;
  top: calc(var(--nav-h) + var(--s4));
}
.sidebar-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r3);
  padding: var(--s5);
}
.sidebar-card h3 { font-family: var(--font-display); font-size: 1rem; margin: 0 0 var(--s3); }
.sidebar-card p { font-size: 0.875rem; color: var(--text-2); margin: 0 0 var(--s3); }
.sidebar-card ol { font-size: 0.85rem; color: var(--text-2); padding-left: var(--s4); margin: 0; }
.sidebar-card li { margin-bottom: var(--s2); }
.sidebar-link { font-size: 0.875rem; font-weight: 600; color: var(--accent); text-decoration: none; }
.sidebar-link:hover { text-decoration: underline; }

.btn { display: inline-flex; align-items: center; gap: var(--s2); padding: var(--s2) var(--s4); border-radius: var(--r2); font-size: 0.82rem; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: all var(--t-fast); font-family: var(--font-body); }
.btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
.btn-primary:hover { background: var(--accent-hover); }
.btn-secondary { background: transparent; color: var(--text-2); border-color: var(--border); }
.btn-secondary:hover { background: var(--bg-alt); color: var(--text); }

@media (max-width: 768px) {
  .spice-layout { grid-template-columns: 1fr; }
  .spice-sidebar { position: static; }
}
</style>

<script>
const selections: Record<string, string> = {};
const outputPlaceholder = document.getElementById('output-placeholder')!;
const outputText = document.getElementById('output-text')!;
const outputActions = document.getElementById('output-actions')!;
const copyBtn = document.getElementById('btn-copy-prompt')!;
const clearBtn = document.getElementById('btn-clear')!;

function buildPrompt(): string {
  const parts: string[] = [];
  if (selections.role) parts.push(selections.role);
  if (selections.context) parts.push(selections.context);
  if (selections.format) parts.push(selections.format);
  if (selections.constraint) parts.push(selections.constraint);
  return parts.join('\n\n');
}

function updateOutput() {
  const prompt = buildPrompt();
  if (!prompt) {
    outputPlaceholder.hidden = false;
    outputText.hidden = true;
    outputActions.hidden = true;
  } else {
    outputPlaceholder.hidden = true;
    outputText.hidden = false;
    outputActions.hidden = false;
    outputText.textContent = prompt;
  }
}

document.querySelectorAll<HTMLButtonElement>('.spice-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const shelf = btn.dataset.shelf!;
    const text = btn.dataset.text!;

    // Deselect all in this shelf group
    document.querySelectorAll<HTMLButtonElement>(`.spice-btn[data-shelf="${shelf}"]`).forEach(b => {
      b.classList.remove('active');
    });

    // Toggle: if this was already selected, deselect it
    if (selections[shelf] === text) {
      delete selections[shelf];
    } else {
      selections[shelf] = text;
      btn.classList.add('active');
    }

    updateOutput();
  });
});

copyBtn.addEventListener('click', async () => {
  const prompt = buildPrompt();
  try { await navigator.clipboard.writeText(prompt); } catch {}
  copyBtn.textContent = 'Copied!';
  setTimeout(() => { copyBtn.textContent = 'Copy Prompt'; }, 2000);
});

clearBtn.addEventListener('click', () => {
  Object.keys(selections).forEach(k => delete selections[k]);
  document.querySelectorAll<HTMLButtonElement>('.spice-btn').forEach(b => b.classList.remove('active'));
  updateOutput();
});
</script>
