---
import Page from '../../layouts/Page.astro';
---
<Page
  title="Submit a Recipe"
  description="Share a prompt that works brilliantly — help other cooks in The Prompt Kitchen."
>
  <section class="page-hero container">
    <h1>👵 Submit a Recipe</h1>
    <p>Found a prompt that works brilliantly? Share it with the kitchen. Community recipes are marked with 👵 and credited to you.</p>
  </section>

  <div class="container submit-layout">
    <form class="submit-form" id="submit-form" novalidate>

      <div class="form-section">
        <h2>The Recipe</h2>

        <div class="field">
          <label for="title">Recipe title <span class="required">*</span></label>
          <input type="text" id="title" name="title" required placeholder="e.g. The Perfect Explanation Request" />
          <span class="field-hint">A short, memorable name for your recipe</span>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="category">Category <span class="required">*</span></label>
            <select id="category" name="category" required>
              <option value="">Choose a category…</option>
              <option>Writing</option>
              <option>Coding</option>
              <option>Learning</option>
              <option>Productivity</option>
              <option>Communication</option>
              <option>Creative Writing</option>
              <option>Decision Making</option>
              <option>Problem Solving</option>
              <option>Critical Thinking</option>
              <option>Career</option>
              <option>Research</option>
              <option>Other</option>
            </select>
          </div>

          <div class="field">
            <label for="difficulty">Difficulty <span class="required">*</span></label>
            <select id="difficulty" name="difficulty" required>
              <option value="">Choose…</option>
              <option value="beginner">🌱 Beginner — anyone can use this</option>
              <option value="home-cook">🍳 Home Cook — some AI experience helps</option>
              <option value="sous-chef">🔪 Sous Chef — for experienced prompters</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label for="prompt">The prompt <span class="required">*</span></label>
          <textarea id="prompt" name="prompt" required rows="8" placeholder="Paste your full prompt here. Use [brackets] for things the user should fill in…"></textarea>
          <span class="field-hint">Include the full, copy-ready prompt. Use [placeholder text] for variable parts.</span>
        </div>
      </div>

      <div class="form-section">
        <h2>Why it works</h2>

        <div class="field">
          <label for="why_it_works">Why does this prompt work? <span class="required">*</span></label>
          <textarea id="why_it_works" name="why_it_works" required rows="4" placeholder="What makes this prompt effective? What does it do that a naive prompt wouldn't?"></textarea>
        </div>

        <div class="field">
          <label for="tips">Tips for getting better results <span class="optional">(optional)</span></label>
          <textarea id="tips" name="tips" rows="3" placeholder="Any tips, variations, or common mistakes to avoid?"></textarea>
        </div>
      </div>

      <div class="form-section">
        <h2>About you</h2>

        <div class="field">
          <label for="contributor">Your handle <span class="optional">(optional)</span></label>
          <input type="text" id="contributor" name="contributor" placeholder="@yourname or YourName — how you'd like to be credited" />
          <span class="field-hint">If you'd like credit when your recipe is published. Leave blank to submit anonymously.</span>
        </div>
      </div>

      <div id="submit-error" class="submit-error" hidden>
        <p id="submit-error-msg">Something went wrong. Please try again.</p>
      </div>

      <div id="submit-success" class="submit-success" hidden>
        <span class="success-icon">🎉</span>
        <h3>Recipe submitted!</h3>
        <p>Thanks for sharing. We'll review it and publish it if it meets our kitchen standards. Community recipes are credited and marked with 👵.</p>
        <a href="/prompts/" class="filter-pill active" style="display:inline-block;text-decoration:none;margin-top:var(--s4);">
          Back to the Recipe Book →
        </a>
      </div>

      <div class="submit-footer" id="submit-footer">
        <button type="submit" class="btn btn-primary" id="submit-btn">
          Submit Recipe 🍳
        </button>
        <p class="submit-note">All submissions are reviewed before publishing. We'll credit you if you leave your handle.</p>
      </div>

    </form>
  </div>
</Page>

<style>
.submit-layout {
  max-width: 680px;
  padding-bottom: var(--s20);
}

.submit-form {
  display: flex;
  flex-direction: column;
  gap: var(--s8);
}

.form-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r3);
  padding: var(--s6);
  display: flex;
  flex-direction: column;
  gap: var(--s5);
}

.form-section h2 {
  font-family: var(--font-display);
  font-size: 1.25rem;
  margin: 0;
  padding-bottom: var(--s4);
  border-bottom: 1px solid var(--border-light);
}

.field {
  display: flex;
  flex-direction: column;
  gap: var(--s2);
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--s4);
}

@media (max-width: 600px) {
  .field-row { grid-template-columns: 1fr; }
}

label {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text);
}

.required {
  color: var(--accent);
}

.optional {
  color: var(--text-3);
  font-weight: 400;
}

input[type="text"],
select,
textarea {
  width: 100%;
  padding: var(--s3) var(--s4);
  border: 1px solid var(--border);
  border-radius: var(--r2);
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 0.9rem;
  transition: border-color var(--t-fast);
  box-sizing: border-box;
}

input[type="text"]:focus,
select:focus,
textarea:focus {
  outline: none;
  border-color: var(--accent);
}

textarea {
  resize: vertical;
  line-height: 1.6;
}

.field-hint {
  font-size: 0.75rem;
  color: var(--text-3);
}

.submit-error {
  background: #FFF5F5;
  border: 1px solid #FECACA;
  border-radius: var(--r2);
  padding: var(--s4) var(--s5);
  color: #991B1B;
  font-size: 0.875rem;
}

[data-theme="dark"] .submit-error {
  background: #2A0A0A;
  border-color: #7F1D1D;
  color: #FCA5A5;
}

.submit-success {
  text-align: center;
  padding: var(--s10);
  background: var(--green-light);
  border: 1px solid #BBF7D0;
  border-radius: var(--r3);
}

[data-theme="dark"] .submit-success {
  background: #0A1F14;
  border-color: #166534;
}

.success-icon {
  font-size: 3rem;
  display: block;
  margin-bottom: var(--s4);
}

.submit-success h3 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  margin: 0 0 var(--s3);
}

.submit-success p {
  color: var(--text-2);
  margin: 0;
}

.submit-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--s4);
  text-align: center;
}

.btn {
  display: inline-flex;
  align-items: center;
  padding: var(--s3) var(--s6);
  border-radius: var(--r2);
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background var(--t-fast);
  border: 1px solid transparent;
}

.btn-primary {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}

.btn-primary:hover {
  background: var(--accent-hover);
}

.btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.submit-note {
  font-size: 0.8rem;
  color: var(--text-3);
  margin: 0;
}
</style>

<script>
const form = document.getElementById('submit-form') as HTMLFormElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const errorBox = document.getElementById('submit-error')!;
const errorMsg = document.getElementById('submit-error-msg')!;
const successBox = document.getElementById('submit-success')!;
const submitFooter = document.getElementById('submit-footer')!;

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  errorBox.hidden = true;

  // Validate
  const required = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[required]');
  let valid = true;
  required.forEach(el => {
    if (!el.value.trim()) { valid = false; el.focus(); }
  });
  if (!valid) {
    errorMsg.textContent = 'Please fill in all required fields.';
    errorBox.hidden = false;
    return;
  }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Submitting…';

  const data = {
    title: (document.getElementById('title') as HTMLInputElement).value.trim(),
    category: (document.getElementById('category') as HTMLSelectElement).value,
    difficulty: (document.getElementById('difficulty') as HTMLSelectElement).value,
    prompt: (document.getElementById('prompt') as HTMLTextAreaElement).value.trim(),
    why_it_works: (document.getElementById('why_it_works') as HTMLTextAreaElement).value.trim(),
    tips: (document.getElementById('tips') as HTMLTextAreaElement).value.trim() || null,
    contributor: (document.getElementById('contributor') as HTMLInputElement).value.trim() || null,
  };

  // Submit to Supabase if configured, otherwise just show success
  let submitted = false;

  if (SUPABASE_URL && SUPABASE_KEY) {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/submissions`, {
        method: 'POST',
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          'Content-Type': 'application/json',
          Prefer: 'return=minimal',
        },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        submitted = true;
      } else {
        const err = await res.text();
        console.error('Submission error:', err);
      }
    } catch (err) {
      console.error('Network error:', err);
    }
  } else {
    // Dev mode — just show success
    submitted = true;
    console.log('Dev mode — would submit:', data);
  }

  if (submitted) {
    form.style.display = 'none';
    successBox.hidden = false;
  } else {
    errorMsg.textContent = 'Something went wrong — please try again or email us directly.';
    errorBox.hidden = false;
    submitBtn.disabled = false;
    submitBtn.textContent = 'Submit Recipe 🍳';
  }
});
</script>
