let active: string | null = null;
let filter = 'all';

function esc(s: string) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderPhases() {
  const el = document.getElementById('phase-flow')!;
  PHASES.forEach(ph => {
    const count = GADGETS.filter(g => g.cat === ph.id).length;
    const btn = document.createElement('button');
    btn.className = 'phase-pill';
    btn.dataset.phase = ph.id;
    btn.title = ph.desc;
    btn.innerHTML = `<span class="phase-pill-icon">${ph.icon}</span><span class="phase-pill-label">${ph.label}</span><span class="phase-pill-count">${count}</span>`;
    btn.addEventListener('click', () => {
      const isActive = btn.classList.contains('active');
      document.querySelectorAll('.phase-pill').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.filter-tab').forEach(t => (t as HTMLElement).classList.toggle('active', (t as HTMLElement).dataset.filter === 'all'));
      if (!isActive) {
        btn.classList.add('active');
        setFilter(ph.id);
        document.querySelectorAll<HTMLElement>('.filter-tab').forEach(t => t.classList.toggle('active', t.dataset.filter === ph.id));
      } else {
        setFilter('all');
      }
    });
    el.appendChild(btn);
  });
}

function renderGrid() {
  const grid = document.getElementById('gadgets-grid')!;
  grid.innerHTML = '';
  let count = 0;
  GADGETS.forEach(g => {
    const hidden = filter !== 'all' && g.cat !== filter;
    if (!hidden) count++;
    const btn = document.createElement('button');
    btn.className = 'gadget-card' + (active === g.id ? ' active' : '');
    btn.dataset.id = g.id;
    btn.style.display = hidden ? 'none' : '';
    btn.innerHTML = `<span class="gc-icon">${g.icon}</span><span class="gc-cat">${esc(g.cat)}</span><span class="gc-name">${esc(g.name)}</span><span class="gc-tagline">${esc(g.tagline)}</span><span class="gc-indicator">▾</span>`;
    btn.addEventListener('click', () => toggleDetail(g.id));
    grid.appendChild(btn);
  });
  (document.getElementById('visible-count') as HTMLElement).textContent = String(count);
}

function setFilter(f: string) {
  filter = f;
  if (active) {
    const g = GADGETS.find(x => x.id === active);
    if (g && filter !== 'all' && g.cat !== filter) closeDetail();
  }
  renderGrid();
}

function toggleDetail(id: string) {
  if (active === id) { closeDetail(); return; }
  active = id;
  const g = GADGETS.find(x => x.id === id)!;
  renderDetail(g);
  renderGrid();
  setTimeout(() => document.getElementById('gadget-detail')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 80);
}

function closeDetail() {
  active = null;
  const el = document.getElementById('gadget-detail')!;
  el.classList.remove('open');
  el.innerHTML = '';
  renderGrid();
}

function renderDetail(g: typeof GADGETS[0]) {
  const rawUrl = BASE_RAW + g.id + '/SKILL.md';
  const ghUrl  = BASE_GH  + g.id;
  const snippet = `Use this skill for ${g.name.toLowerCase()}:\n${rawUrl}`;
  const whenHtml = g.when.map(w => `<li>${esc(w)}</li>`).join('');
  const principlesHtml = g.principles.map(p => `<div class="principle"><div class="principle-title">${esc(p.t)}</div><div class="principle-desc">${esc(p.d)}</div></div>`).join('');
  const el = document.getElementById('gadget-detail')!;
  el.innerHTML = `
    <div class="detail-header">
      <span class="detail-icon">${g.icon}</span>
      <div class="detail-header-text">
        <h2 class="detail-name">${esc(g.name)}</h2>
        <p class="detail-tagline">${esc(g.tagline)}</p>
        <span class="gc-cat">${esc(g.cat)}</span>
      </div>
      <button class="btn btn-secondary btn-sm detail-close" onclick="closeDetailBtn()">✕ Close</button>
    </div>
    <div class="detail-body">
      <div class="detail-section">
        <div class="detail-section-title">Overview</div>
        <p class="detail-overview">${esc(g.overview)}</p>
      </div>
      <div class="detail-section">
        <div class="detail-section-title">When to use</div>
        <ul class="detail-when">${whenHtml}</ul>
      </div>
      <div class="detail-section">
        <div class="detail-section-title">Core principles</div>
        <div class="principles-grid">${principlesHtml}</div>
      </div>
      <div class="detail-section">
        <div class="detail-section-title">Install this gadget</div>
        <div class="install-box">
          <div class="install-label">Paste into your AI agent, or add to CLAUDE.md / AGENTS.md</div>
          <pre class="install-snippet" id="snip-${esc(g.id)}">${esc(snippet)}</pre>
          <div class="install-actions">
            <button class="btn btn-primary btn-sm" onclick="copySnip('${esc(g.id)}')">📋 Copy snippet</button>
            <a href="${esc(ghUrl)}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">↗ GitHub</a>
            <a href="${esc(rawUrl)}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">📄 Raw SKILL.md</a>
            <span class="copy-confirm" id="conf-${esc(g.id)}">Copied!</span>
          </div>
        </div>
      </div>
    </div>`;
  el.classList.add('open');
}

function copySnip(id: string) {
  const el = document.getElementById('snip-' + id);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent?.trim() ?? '').then(() => {
    const c = document.getElementById('conf-' + id);
    if (c) { c.style.display = 'inline'; setTimeout(() => { c.style.display = 'none'; }, 2200); }
  });
}

// expose to inline onclick attrs
(window as any).closeDetailBtn = closeDetail;
(window as any).copySnip = copySnip;

document.addEventListener('DOMContentLoaded', () => {
  renderPhases();
  renderGrid();

  document.querySelectorAll<HTMLElement>('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('.phase-pill').forEach(p => p.classList.toggle('active', (p as HTMLElement).dataset.phase === tab.dataset.filter));
      setFilter(tab.dataset.filter ?? 'all');
    });
  });
});
</script>
