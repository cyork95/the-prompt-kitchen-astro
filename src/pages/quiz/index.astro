---
import Page from '../../layouts/Page.astro';
---
<Page title="Ask the Chef" description="Answer a few questions and get a personalised AI tool recommendation.">
  <section class="page-hero container">
    <h1>👨‍🍳 Ask the Chef</h1>
    <p>Not sure which AI tool to use? Answer a few questions and get a personalised recommendation.</p>
  </section>

  <div class="container quiz-layout">
    <div class="quiz-card" id="quiz-card">
      <!-- Step indicator -->
      <div class="quiz-steps" id="quiz-steps">
        <div class="step active" data-step="0"></div>
        <div class="step" data-step="1"></div>
        <div class="step" data-step="2"></div>
        <div class="step" data-step="3"></div>
      </div>

      <div id="quiz-body">
        <!-- Questions rendered by JS -->
      </div>
    </div>

    <aside class="quiz-sidebar">
      <div class="sidebar-card">
        <h3>🍳 Not sure where to start?</h3>
        <p>The Appliance Guide has a full comparison of all major AI models.</p>
        <a href="/models/" class="sidebar-link">Compare models →</a>
      </div>
      <div class="sidebar-card">
        <h3>📖 Just want recipes?</h3>
        <p>Skip the quiz and browse 26 ready-to-use prompts.</p>
        <a href="/prompts/" class="sidebar-link">Recipe Book →</a>
      </div>
    </aside>
  </div>
</Page>

<style>
.page-hero { padding: var(--s12) 0 var(--s8); max-width: var(--container-narrow); }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(2rem,5vw,3rem); margin: 0 0 var(--s3); }
.page-hero p { color: var(--text-2); font-size: 1.05rem; margin: 0; max-width: 560px; }
.quiz-layout { display: grid; grid-template-columns: 1fr 260px; gap: var(--s8); padding-bottom: var(--s20); align-items: start; }
.quiz-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r4); padding: var(--s8); min-height: 320px; }
.quiz-steps { display: flex; gap: var(--s2); margin-bottom: var(--s8); }
.step { height: 4px; flex: 1; background: var(--border); border-radius: 2px; transition: background var(--t-fast); }
.step.active, .step.done { background: var(--accent); }
.quiz-question { font-family: var(--font-display); font-size: 1.4rem; margin: 0 0 var(--s6); line-height: 1.3; }
.quiz-options { display: flex; flex-direction: column; gap: var(--s3); }
.quiz-option { display: flex; align-items: flex-start; gap: var(--s4); padding: var(--s4) var(--s5); border: 1.5px solid var(--border); border-radius: var(--r3); background: var(--bg-alt); cursor: pointer; text-align: left; font-family: var(--font-body); transition: all var(--t-fast); }
.quiz-option:hover { border-color: var(--accent); background: var(--accent-light); }
.option-icon { font-size: 1.3rem; flex-shrink: 0; }
.option-text { display: flex; flex-direction: column; gap: 2px; }
.option-label { font-size: 0.9rem; font-weight: 600; color: var(--text); }
.option-sub { font-size: 0.78rem; color: var(--text-3); }
.quiz-result { display: flex; flex-direction: column; gap: var(--s5); }
.result-header { display: flex; align-items: center; gap: var(--s4); }
.result-emoji { font-size: 2.5rem; }
.result-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-3); display: block; margin-bottom: 4px; }
.result-name { font-family: var(--font-display); font-size: 1.5rem; margin: 0; }
.result-reason { font-size: 0.95rem; color: var(--text-2); line-height: 1.7; margin: 0; }
.result-also h3 { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); margin: 0 0 var(--s3); }
.also-list { display: flex; flex-direction: column; gap: var(--s2); }
.also-item { font-size: 0.875rem; color: var(--text-2); padding: var(--s2) var(--s3); background: var(--bg-alt); border-radius: var(--r2); }
.result-actions { display: flex; gap: var(--s3); flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; padding: var(--s2) var(--s5); border-radius: var(--r2); font-size: 0.875rem; font-weight: 600; text-decoration: none; cursor: pointer; border: 1px solid transparent; transition: all var(--t-fast); font-family: var(--font-body); }
.btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
.btn-primary:hover { background: var(--accent-hover); }
.btn-secondary { background: transparent; color: var(--text-2); border-color: var(--border); }
.btn-secondary:hover { background: var(--bg-alt); }
.quiz-sidebar { display: flex; flex-direction: column; gap: var(--s4); position: sticky; top: calc(var(--nav-h) + var(--s4)); }
.sidebar-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r3); padding: var(--s5); }
.sidebar-card h3 { font-family: var(--font-display); font-size: 1rem; margin: 0 0 var(--s2); }
.sidebar-card p { font-size: 0.875rem; color: var(--text-2); margin: 0 0 var(--s3); }
.sidebar-link { font-size: 0.875rem; font-weight: 600; color: var(--accent); text-decoration: none; }
.sidebar-link:hover { text-decoration: underline; }
@media (max-width: 768px) { .quiz-layout { grid-template-columns: 1fr; } .quiz-sidebar { position: static; } }
</style>

<script>
const questions = [
  {
    q: "What's your main use case?",
    options: [
      { icon: '✍️', label: 'Writing & editing', sub: 'emails, docs, content, editing', key: 'writing' },
      { icon: '💻', label: 'Coding & debugging', sub: 'code review, explaining errors, writing scripts', key: 'coding' },
      { icon: '🔍', label: 'Research & learning', sub: 'summarising, fact-checking, understanding new topics', key: 'research' },
      { icon: '🎨', label: 'Creative work', sub: 'brainstorming, storytelling, images, video', key: 'creative' },
    ],
  },
  {
    q: "How do you prefer to work?",
    options: [
      { icon: '⚡', label: 'Quick answers', sub: 'I want fast, direct responses', key: 'fast' },
      { icon: '📄', label: 'Long documents', sub: 'I work with large files and need deep context', key: 'long' },
      { icon: '🌐', label: 'Current information', sub: 'I need up-to-date facts and sources', key: 'current' },
      { icon: '🔒', label: 'Privacy matters', sub: 'I\'d rather not send data to big tech', key: 'private' },
    ],
  },
  {
    q: "What's your budget?",
    options: [
      { icon: '🆓', label: 'Free only', sub: 'No subscriptions', key: 'free' },
      { icon: '💰', label: 'Up to $20/month', sub: 'One subscription is fine', key: 'paid' },
      { icon: '🏢', label: 'Team / business', sub: 'Multiple users, API access', key: 'business' },
    ],
  },
  {
    q: "Your experience level?",
    options: [
      { icon: '🌱', label: 'Just starting out', sub: 'I want something easy and forgiving', key: 'beginner' },
      { icon: '🍳', label: 'Comfortable', sub: 'I know the basics, want to go deeper', key: 'intermediate' },
      { icon: '🔪', label: 'Power user', sub: 'I want full control and customisation', key: 'advanced' },
    ],
  },
];

const recommendations: Record<string, { name: string; emoji: string; url: string; reason: string; also: string[] }> = {
  'writing-long': { name: 'Claude', emoji: '🟠', url: 'https://claude.ai', reason: 'Claude handles long documents exceptionally well and produces nuanced, careful writing. Its 200K context window means it can read your entire document before responding.', also: ['ChatGPT for quick edits', 'Grammarly for grammar-only fixes'] },
  'writing-fast': { name: 'ChatGPT', emoji: '🟢', url: 'https://chat.openai.com', reason: 'ChatGPT is fast, versatile, and excellent for everyday writing tasks. GPT-4o handles drafts, rewrites, and edits with minimal fuss.', also: ['Claude for longer documents', 'Notion AI if you\'re already in Notion'] },
  'coding': { name: 'Claude', emoji: '🟠', url: 'https://claude.ai', reason: 'Claude is consistently rated the best model for code. It explains errors clearly, follows complex refactoring instructions, and handles large codebases.', also: ['GitHub Copilot for in-editor completions', 'ChatGPT for quick scripts'] },
  'research-current': { name: 'Perplexity', emoji: '🟣', url: 'https://perplexity.ai', reason: 'Perplexity is built for research — it searches the web in real time and cites every source. Best tool for anything where recency and accuracy matter.', also: ['Claude for synthesising long reports', 'Gemini for Google-integrated research'] },
  'research': { name: 'Claude', emoji: '🟠', url: 'https://claude.ai', reason: 'Claude excels at synthesising large amounts of information, maintaining nuance, and being honest about uncertainty. Ideal for deep research and summarisation.', also: ['Perplexity if you need current sources', 'NotebookLM for document libraries'] },
  'creative': { name: 'ChatGPT', emoji: '🟢', url: 'https://chat.openai.com', reason: 'ChatGPT with DALL·E covers text and images in one place. For video and music, see the Kitchen Cinema and Kitchen Radio pages.', also: ['Midjourney for better image quality', 'Suno for music generation'] },
  'private': { name: 'Ollama (local)', emoji: '⚫', url: 'https://ollama.ai', reason: 'Ollama lets you run open-source models (Llama, Mistral) entirely on your own machine. Nothing leaves your computer. Free, but requires some setup.', also: ['Mistral (privacy-focused EU company)', 'Claude for the most privacy-conscious hosted option'] },
  default: { name: 'ChatGPT', emoji: '🟢', url: 'https://chat.openai.com', reason: 'ChatGPT is the best all-rounder for most use cases. The free tier is generous, it handles almost any task, and GPT-4o is genuinely impressive.', also: ['Claude for writing and long documents', 'Perplexity for current research'] },
};

const answers: Record<number, string> = {};
let step = 0;

function getRecommendation() {
  const useCase = answers[0];
  const style = answers[1];
  const key = `${useCase}-${style}`;
  return recommendations[key] || recommendations[useCase] || recommendations.default;
}

function renderQuestion(i: number) {
  const q = questions[i];
  const body = document.getElementById('quiz-body')!;
  body.innerHTML = `
    <p class="quiz-question">${q.q}</p>
    <div class="quiz-options">
      ${q.options.map(o => `
        <button class="quiz-option" data-key="${o.key}">
          <span class="option-icon">${o.icon}</span>
          <span class="option-text">
            <span class="option-label">${o.label}</span>
            <span class="option-sub">${o.sub}</span>
          </span>
        </button>
      `).join('')}
    </div>
  `;

  body.querySelectorAll<HTMLButtonElement>('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      answers[i] = btn.dataset.key!;
      // Mark step done
      document.querySelectorAll('.step').forEach((s, idx) => {
        s.classList.toggle('done', idx < i + 1);
        s.classList.toggle('active', idx === i + 1);
      });

      step = i + 1;
      if (step < questions.length) {
        renderQuestion(step);
      } else {
        renderResult();
      }
    });
  });
}

function renderResult() {
  const rec = getRecommendation();
  const body = document.getElementById('quiz-body')!;
  // Mark all steps done
  document.querySelectorAll('.step').forEach(s => { s.classList.add('done'); s.classList.remove('active'); });

  body.innerHTML = `
    <div class="quiz-result">
      <div class="result-header">
        <span class="result-emoji">${rec.emoji}</span>
        <div>
          <span class="result-label">The Chef recommends</span>
          <h2 class="result-name">${rec.name}</h2>
        </div>
      </div>
      <p class="result-reason">${rec.reason}</p>
      ${rec.also.length ? `
        <div class="result-also">
          <h3>Also worth trying</h3>
          <div class="also-list">
            ${rec.also.map(a => `<div class="also-item">${a}</div>`).join('')}
          </div>
        </div>
      ` : ''}
      <div class="result-actions">
        <a href="${rec.url}" target="_blank" rel="noopener" class="btn btn-primary">Try ${rec.name} →</a>
        <button class="btn btn-secondary" id="btn-retake">Retake quiz</button>
      </div>
    </div>
  `;

  document.getElementById('btn-retake')?.addEventListener('click', () => {
    step = 0;
    Object.keys(answers).forEach(k => delete (answers as any)[k]);
    document.querySelectorAll('.step').forEach((s, i) => {
      s.classList.toggle('active', i === 0);
      s.classList.remove('done');
    });
    renderQuestion(0);
  });
}

// Init
renderQuestion(0);
</script>
