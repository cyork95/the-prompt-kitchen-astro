---
const year = new Date().getFullYear();
---
<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo" style="margin-bottom:var(--s3);display:inline-flex;" aria-label="Home">
          <svg class="nav-logo-icon" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M8 6C8 6 6 10 6 16C6 22 10 26 16 26C22 26 26 22 26 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M16 6V16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M12 10L16 6L20 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="16" r="3" fill="currentColor"/>
          </svg>
          <span class="nav-logo-text">The Prompt Kitchen</span>
        </a>
        <p>Simple recipes for getting the most out of AI. Free, open, and always will be.</p>
      </div>

      <div class="footer-col">
        <h4>Recipes</h4>
        <ul>
          <li><a href="/prompts/">Recipe Book</a></li>
          <li><a href="/cookbooks/">Cookbooks</a></li>
          <li><a href="/daily/">Daily Specials</a></li>
          <li><a href="/pantry/">The Pantry</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Prep</h4>
        <ul>
          <li><a href="/context/">Kitchen Prep</a></li>
          <li><a href="/meal-prep/">Meal Prep</a></li>
          <li><a href="/guardrails/">Guardrails</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Tools</h4>
        <ul>
          <li><a href="/spice-rack/">Spice Rack</a></li>
          <li><a href="/model-tester/">Test Kitchen</a></li>
          <li><a href="/models/">Appliance Guide</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Community</h4>
        <ul>
          <li><a href="/submit/">Submit a Recipe</a></li>
          <li><a href="/my-kitchen/">My Kitchen</a></li>
          <li><a href="/challenges/">Cook-Off</a></li>
          <li><a href="/support/">Tip Jar</a></li>
          <li><a href="https://github.com/cyork95/the-prompt-kitchen" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} The Prompt Kitchen · <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener" style="color:inherit">CC BY 4.0</a></span>
      <a href="mailto:coyofroyo@yorkdevelops.com" style="color:inherit;text-decoration:none;">coyofroyo@yorkdevelops.com</a>
      <span>Developed with ♥ by <a href="https://yorkdevelops.com" rel="noopener" style="color:inherit">York.Dev</a></span>
      <div class="footer-privacy">
        <span class="privacy-dot"></span>
        <span>No tracking · No cookies · No ads · No account needed</span>
      </div>
    </div>
  </div>
</footer>
