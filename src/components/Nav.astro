---
// Mega-menu navigation — 5 groups, full-width panels
// Groups are defined here; rendered by MegaItem
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="The Prompt Kitchen — Home">
      <svg class="nav-logo-icon" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M8 6C8 6 6 10 6 16C6 22 10 26 16 26C22 26 26 22 26 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M16 6V16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M12 10L16 6L20 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="16" cy="16" r="3" fill="currentColor"/>
      </svg>
      <span class="nav-logo-text">The Prompt Kitchen</span>
    </a>

    <!-- Desktop mega-menu -->
    <ul class="nav-links mega-nav" role="list" id="mega-nav">

      <!-- 📖 Recipes -->
      <li class="mega-item">
        <button class="mega-btn" aria-haspopup="true" aria-expanded="false" data-mega="recipes">
          📖 Recipes <span class="mega-chevron">▾</span>
        </button>
        <div class="mega-panel" id="mega-panel-recipes" hidden>
          <div class="mega-grid">
            <div class="mega-col">
              <span class="mega-col-header">Core</span>
              <a href="/prompts/" class="mega-link">
                <span class="mega-link-icon">📖</span>
                <span><strong>Recipe Book</strong><small>26 ready-to-copy prompts</small></span>
              </a>
              <a href="/daily/" class="mega-link">
                <span class="mega-link-icon">⭐</span>
                <span><strong>Daily Specials</strong><small>Fresh prompt every day</small></span>
              </a>
            </div>
            <div class="mega-col">
              <span class="mega-col-header">Collections</span>
              <a href="/cookbooks/" class="mega-link">
                <span class="mega-link-icon">📚</span>
                <span><strong>Cookbooks</strong><small>Curated by audience</small></span>
              </a>
              <a href="/cookbooks/indie-hacker/" class="mega-link mega-link--sub">
                <span>💻 Indie Hacker</span>
              </a>
              <a href="/cookbooks/student/" class="mega-link mega-link--sub">
                <span>🎓 Student</span>
              </a>
              <a href="/cookbooks/creator/" class="mega-link mega-link--sub">
                <span>🎨 Creator</span>
              </a>
              <a href="/cookbooks/startup-founder/" class="mega-link mega-link--sub">
                <span>🚀 Startup Founder</span>
              </a>
            </div>
            <div class="mega-col">
              <span class="mega-col-header">Ingredients</span>
              <a href="/spice-rack/" class="mega-link">
                <span class="mega-link-icon">🌶️</span>
                <span><strong>Spice Rack</strong><small>Build your own prompt</small></span>
              </a>
              <a href="/pantry/" class="mega-link">
                <span class="mega-link-icon">🥫</span>
                <span><strong>The Pantry</strong><small>Reusable building blocks</small></span>
              </a>
            </div>
          </div>
        </div>
      </li>

      <!-- 🧑‍🍳 Prep -->
      <li class="mega-item">
        <button class="mega-btn" aria-haspopup="true" aria-expanded="false" data-mega="prep">
          🧑‍🍳 Prep <span class="mega-chevron">▾</span>
        </button>
        <div class="mega-panel" id="mega-panel-prep" hidden>
          <div class="mega-grid mega-grid--3">
            <div class="mega-col">
              <span class="mega-col-header">Before you cook</span>
              <a href="/context/" class="mega-link">
                <span class="mega-link-icon">🧑‍🍳</span>
                <span><strong>Kitchen Prep</strong><small>How to give AI context</small></span>
